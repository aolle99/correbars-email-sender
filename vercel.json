{
  "version": 2,
  "builds": [
    {
      "src": "api/send.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/send",
      "dest": "/api/send.js"
    },
    {
      "src": "/(.*\\.(jpg|jpeg|png|gif|webp|svg|ico))",
      "dest": "/public/$1"
    }
  ]
}